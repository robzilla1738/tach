{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tach.dev/schemas/bench.schema.json",
  "title": "Tach Suite Bench Output",
  "description": "The JSON emitted by `tach bench --suite <dir> --json`: per-case repair outcomes plus aggregate agent-loop metrics (time-to-green, patches-to-green, tests-run, regressions).",
  "type": "object",
  "required": ["cases", "totals"],
  "additionalProperties": false,
  "properties": {
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "outcome"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "outcome": { "type": "object" }
        }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cases": { "type": "integer", "minimum": 0 },
        "green": { "type": "integer", "minimum": 0 },
        "laps": { "type": "integer", "minimum": 0 },
        "patches_applied": { "type": "integer", "minimum": 0 },
        "tests_run": { "type": "integer", "minimum": 0 },
        "regressions": { "type": "integer", "minimum": 0 },
        "diff_chars": { "type": "integer", "minimum": 0 },
        "us": { "type": "integer", "minimum": 0, "description": "Wall-clock microseconds; excluded from determinism comparisons." }
      }
    }
  }
}
